# Application
PORT=3000
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=authori
DB_PASSWORD=authori_password
DB_NAME=authori_db

# JWT / Signing
JWT_ISSUER=https://auth.example.com
JWT_ACCESS_TOKEN_EXPIRY=3600
JWT_REFRESH_TOKEN_EXPIRY=2592000

# Admin
PLATFORM_ADMIN_SECRET=change_me_in_production
JWT_ADMIN_SECRET=change_me_admin_secret
JWT_ADMIN_EXPIRY=86400

# CORS (쉼표로 여러 origin 구분, 비어있으면 CORS 비활성화)
CORS_ORIGINS=http://localhost:5173
LOGIN_PAGE_URL=http://localhost:5173/login

# SMTP (회원가입 이메일 인증 메일 발송용. SMTP_HOST가 비어있으면 메일이
# 발송되지 않고 인증 링크가 서버 로그에만 출력됩니다 — 개발용 폴백)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Authori <no-reply@authori.local>"
# 개발환경(NODE_ENV=development) 전용 — 값이 설정되면 모든 메일 수신자를
# 이 주소로 강제 변경합니다(실 사용자에게 잘못 발송되는 것을 방지). 비어있으면 비활성.
SMTP_DEV_REDIRECT_TO=
# TLS 인증서 검증 여부. 자체 서명(self-signed) 인증서를 쓰는 개발용 SMTP 서버라면
# false 로 설정해 검증을 우회합니다. 운영환경에서는 반드시 true(기본값)로 둡니다.
SMTP_TLS_REJECT_UNAUTHORIZED=true
# 이메일 인증 토큰 유효시간 (초, 기본 24시간)
EMAIL_VERIFICATION_TTL=86400

VITE_API_BASE_URL=http://localhost:3000
