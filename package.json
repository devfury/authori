{
  "name": "authori",
  "version": "1.3.1",
  "private": true,
  "description": "멀티테넌트 OAuth2 인증 서비스 (Turborepo 모노레포)",
  "license": "UNLICENSED",
  "packageManager": "bun@1.2.17",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "typecheck": "turbo run typecheck",
    "format": "turbo run format",
    "dev:api": "turbo run dev --filter=@authori/api",
    "dev:web": "turbo run dev --filter=@authori/web",
    "build:api": "turbo run build --filter=@authori/api",
    "build:web": "turbo run build --filter=@authori/web",
    "migration:show": "turbo run migration:show --filter=@authori/api",
    "migration:show:dev": "turbo run migration:show:dev --filter=@authori/api",
    "migration:show:prd": "turbo run migration:show:prd --filter=@authori/api",
    "migration:run": "turbo run migration:run --filter=@authori/api",
    "migration:run:dev": "turbo run migration:run:dev --filter=@authori/api",
    "migration:run:prd": "turbo run migration:run:prd --filter=@authori/api"
  },
  "devDependencies": {
    "turbo": "^2.5.6"
  },
  "trustedDependencies": [
    "unrs-resolver"
  ]
}
