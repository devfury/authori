# Application
PORT=3000
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=authori
DB_PASSWORD=authori_password
DB_NAME=authori_db

# JWT / Signing
JWT_ISSUER=https://auth.example.com
JWT_ACCESS_TOKEN_EXPIRY=3600
JWT_REFRESH_TOKEN_EXPIRY=2592000

# Admin
PLATFORM_ADMIN_SECRET=change_me_in_production
JWT_ADMIN_SECRET=change_me_admin_secret
JWT_ADMIN_EXPIRY=86400

# CORS (쉼표로 여러 origin 구분, 비어있으면 CORS 비활성화)
CORS_ORIGINS=http://localhost:5173
LOGIN_PAGE_URL=http://localhost:5173/login

# SMTP (회원가입 이메일 인증 메일 발송용. SMTP_HOST가 비어있으면 메일이
# 발송되지 않고 인증 링크가 서버 로그에만 출력됩니다 — 개발용 폴백)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Authori <no-reply@authori.local>"
# 이메일 인증 토큰 유효시간 (초, 기본 24시간)
EMAIL_VERIFICATION_TTL=86400