# 서버 포트 (기본값: 3002)
PORT=3002

# Credential 헤더 검증 (설정 시 요청 헤더에 해당 값이 있어야 인증 허용)
# Authori의 ExternalAuthProvider.credentialHeader / credentialValue와 일치해야 함
CREDENTIAL_HEADER=X-Provider-Secret
CREDENTIAL_VALUE=my-secret-token

# 기본 사용자 목록 오버라이드 (JSON 배열, 생략 시 alice/bob 기본값 사용)
# USERS_JSON=[{"email":"alice@example.com","password":"alice123","name":"Alice Kim","loginId":"alice","profile":{"department":"engineering"}}]
